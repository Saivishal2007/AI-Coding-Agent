{
  "name": "ai-coding-agent-v2",
  "displayName": "AI Coding Agent",
  "description": "An AI-powered repository-aware coding assistant for Visual Studio Code with repository understanding, safe code editing, intelligent context retrieval, and multi-file editing support.",
  "version": "1.0.0",
  "publisher": "<YOUR_PUBLISHER_NAME>",
  "license": "MIT",

  "engines": {
    "vscode": "^1.125.0"
  },

  "categories": [
    "Programming Languages",
    "Machine Learning"
  ],

  "keywords": [
    "ai",
    "assistant",
    "coding",
    "code",
    "gemini",
    "developer",
    "repository",
    "automation",
    "chat",
    "productivity"
  ],

  "icon": "resources/icon.png",

  "activationEvents": [
    "onView:aiCodingAgent.chatView"
  ],

  "main": "./dist/extension.js",

  "contributes": {
    "commands": [
      {
        "command": "ai-coding-agent-v2.openChat",
        "title": "Open AI Coding Agent"
      }
    ],

    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiCodingAgent",
          "title": "AI Coding Agent",
          "icon": "resources/icon.svg"
        }
      ]
    },

    "views": {
      "aiCodingAgent": [
        {
          "type": "webview",
          "id": "aiCodingAgent.chatView",
          "name": "Chat"
        }
      ]
    }
  },

  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },

  "files": [
    "dist",
    "media",
    "resources"
  ],

  "dependencies": {
    "copy-webpack-plugin": "^14.0.0",
    "dompurify": "^3.4.12"
  },

  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "eslint": "^10.5.0",
    "ts-loader": "^9.6.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  },

  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },

  "repository": {
    "type": "git",
    "url": "https://github.com/<YOUR_GITHUB_USERNAME>/AI-Coding-Agent"
  },

  "homepage": "https://github.com/<YOUR_GITHUB_USERNAME>/AI-Coding-Agent",

  "bugs": {
    "url": "https://github.com/<YOUR_GITHUB_USERNAME>/AI-Coding-Agent/issues"
  }
}